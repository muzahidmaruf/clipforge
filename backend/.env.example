# Ollama Cloud — get a key at https://ollama.com/settings/keys
# Model options: qwen3.5-cloud, gemma3:27b-cloud, llama3.1:70b-cloud, etc.
# See https://ollama.com/library/qwen3.5 for available Qwen models
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_key_here
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_CLOUD_MODEL=qwen3.5-cloud

# Redis (broker for Celery)
REDIS_URL=redis://localhost:6379/0

# Absolute path to ffmpeg binary (optional — falls back to PATH)
FFMPEG_PATH=

# ─── Supabase auth ─────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Set false to disable JWT enforcement (e.g. local dev without login)
REQUIRE_AUTH=true
