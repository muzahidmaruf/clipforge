# Ollama Cloud — get a key at https://ollama.com/settings/keys
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_key_here
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_CLOUD_MODEL=gemma4:31b-cloud

# Redis (broker for Celery)
REDIS_URL=redis://localhost:6379/0

# Absolute path to ffmpeg binary (optional — falls back to PATH)
FFMPEG_PATH=
